<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.movies_ar" 
       name="أفلام ومسلسلات عربية" 
       version="2.0.0" 
       provider-name="ArabicMovies">
    
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.0"/>
        <import addon="script.module.beautifulsoup4" version="4.9.3"/>
    </requires>
    
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    
    <extension point="xbmc.addon.metadata">
        <summary lang="ar">أفلام ومسلسلات عربية بجودة عالية</summary>
        <description lang="ar">إضافة عربية متكاملة لعرض أحدث الأفلام والمسلسلات العربية والمدبلجة والمترجمة من أفضل 15 موقع عربي مع فلاتر متقدمة حسب النوع والدولة والسنة وجودة 4k و 1080p</description>
        <language>ar</language>
        <platform>all</platform>
        <license>GPL-3.0</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>